import { useState } from 'react'

const transactions = [
  { title: '转账-转到银行卡', time: '2024-05-25 10:30', amount: '-2,000.00', type: 'out' },
  { title: '余额宝-转入', time: '2024-05-24 15:20', amount: '+5,000.00', type: 'in' },
  { title: '手机充值', time: '2024-05-23 09:15', amount: '-100.00', type: 'out' },
  { title: '收款-张三', time: '2024-05-22 18:45', amount: '+500.00', type: 'in' },
  { title: '生活缴费-电费', time: '2024-05-21 12:00', amount: '-156.80', type: 'out' },
  { title: '花呗还款', time: '2024-05-20 08:30', amount: '-358.00', type: 'out' },
  { title: '余额宝-收益', time: '2024-05-19 06:00', amount: '+0.96', type: 'in' },
  { title: '口碑外卖', time: '2024-05-18 12:30', amount: '-35.50', type: 'out' },
  { title: '转账-转到银行卡', time: '2024-05-17 14:00', amount: '-1,500.00', type: 'out' },
  { title: '收款-李四', time: '2024-05-16 09:20', amount: '+800.00', type: 'in' },
]

export default function BalancePage({ onBack }) {
  const [balance, setBalance] = useState(() => {
    return localStorage.getItem('alipay_balance') || '12,345.67'
  })
  const [visible, setVisible] = useState(true)
  const [devMode, setDevMode] = useState(false)
  const [editValue, setEditValue] = useState(balance)
  const [activeTab, setActiveTab] = useState('all')
  let clickTimer = null

  const handleLongPress = () => {
    if (!clickTimer) {
      clickTimer = setTimeout(() => {
        setDevMode(true)
        setEditValue(balance)
        clickTimer = null
      }, 2000)
    }
  }

  const cancelLongPress = () => {
    if (clickTimer) {
      clearTimeout(clickTimer)
      clickTimer = null
    }
  }

  const handleSave = () => {
    const val = editValue.replace(/[^\d.]/g, '')
    if (val && !isNaN(val)) {
      const formatted = Number(val).toLocaleString('zh-CN', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      })
      setBalance(formatted)
      localStorage.setItem('alipay_balance', formatted)
    }
    setDevMode(false)
  }

  return (
    <div className="min-h-screen bg-alipay-bg pb-20">
      {/* Header */}
      <div className="bg-gradient-to-b from-alipay-blue to-alipay-blue-dark px-4 pt-3 pb-8">
        <div className="flex items-center justify-between">
          <button onClick={onBack} className="active:opacity-60 p-1 -ml-1">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <span className="text-white text-lg font-medium">余额</span>
          <button className="active:opacity-60">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" strokeWidth="1.5" strokeLinecap="round">
              <circle cx="12" cy="5" r="1" fill="white" stroke="none"/>
              <circle cx="12" cy="12" r="1" fill="white" stroke="none"/>
              <circle cx="12" cy="19" r="1" fill="white" stroke="none"/>
            </svg>
          </button>
        </div>

        {/* Balance display */}
        <div className="mt-6 text-center">
          <div className="flex items-center justify-center gap-2 text-white/80 text-sm">
            <span>余额 (元)</span>
            <button onClick={() => setVisible(!visible)} className="active:opacity-60">
              {visible ? (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <circle cx="12" cy="12" r="3" stroke="white" strokeWidth="1.5"/>
                  <path d="M2 12s4-8 10-8 10 8 10 8-4 8-10 8-10-8-10-8z" stroke="white" strokeWidth="1.5"/>
                </svg>
              ) : (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path d="M2 2l20 20" stroke="white" strokeWidth="1.5" strokeLinecap="round"/>
                  <path d="M6.5 6.5A9.5 9.5 0 0112 4c6 0 10 8 10 8a12.6 12.6 0 01-3.5 4.8" stroke="white" strokeWidth="1.5" strokeLinecap="round"/>
                </svg>
              )}
            </button>
          </div>
          <div
            className="mt-2 select-none"
            onMouseDown={handleLongPress}
            onMouseUp={cancelLongPress}
            onMouseLeave={cancelLongPress}
            onTouchStart={handleLongPress}
            onTouchEnd={cancelLongPress}
          >
            {devMode ? (
              <div className="flex items-center justify-center gap-2" onClick={e => e.stopPropagation()}>
                <span className="text-white text-lg">¥</span>
                <input
                  autoFocus
                  type="text"
                  value={editValue}
                  onChange={e => setEditValue(e.target.value)}
                  className="bg-white/20 text-white text-2xl font-bold px-3 py-1 rounded-btn outline-none w-40 border border-white/30 text-center"
                />
                <button
                  onClick={handleSave}
                  className="bg-white text-alipay-blue px-3 py-1 rounded-btn text-sm font-medium active:opacity-80"
                >
                  确定
                </button>
              </div>
            ) : (
              <div className="text-white text-4xl font-bold tracking-tight">
                {visible ? balance : '******'}
              </div>
            )}
          </div>
          {devMode && (
            <p className="text-white/50 text-xs mt-2">开发者模式 - 长按余额触发，输入新金额后确定</p>
          )}

          {/* Action buttons */}
          <div className="flex justify-center gap-8 mt-6">
            {[
              { label: '充值', icon: '📥' },
              { label: '提现', icon: '📤' },
              { label: '转账', icon: '💸' },
            ].map((a, i) => (
              <button key={i} className="flex flex-col items-center gap-1 active:opacity-60">
                <div className="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center text-xl">
                  {a.icon}
                </div>
                <span className="text-white text-xs">{a.label}</span>
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Tab bar */}
      <div className="bg-alipay-card mx-4 -mt-3 relative z-10 rounded-card shadow-sm">
        <div className="flex border-b border-alipay-divider">
          {[
            { key: 'all', label: '全部' },
            { key: 'income', label: '收入' },
            { key: 'outcome', label: '支出' },
          ].map((tab) => (
            <button
              key={tab.key}
              onClick={() => setActiveTab(tab.key)}
              className={`flex-1 py-3 text-sm transition-colors relative ${
                activeTab === tab.key
                  ? 'text-alipay-blue font-medium'
                  : 'text-alipay-text-secondary'
              }`}
            >
              {tab.label}
              {activeTab === tab.key && (
                <div className="absolute bottom-0 left-1/2 -translate-x-1/2 w-6 h-0.5 bg-alipay-blue rounded-full" />
              )}
            </button>
          ))}
        </div>

        {/* Transaction list */}
        <div>
          {transactions
            .filter((t) => {
              if (activeTab === 'income') return t.type === 'in'
              if (activeTab === 'outcome') return t.type === 'out'
              return true
            })
            .map((tx, i) => (
              <div
                key={i}
                className="px-4 py-3 flex items-center justify-between border-b border-alipay-divider last:border-b-0 active:bg-gray-50 cursor-pointer"
              >
                <div>
                  <div className="text-sm text-alipay-text">{tx.title}</div>
                  <div className="text-xs text-alipay-text-tertiary mt-0.5">{tx.time}</div>
                </div>
                <span
                  className={`text-sm font-medium ${
                    tx.type === 'in' ? 'text-alipay-green' : 'text-alipay-text'
                  }`}
                >
                  {tx.amount}
                </span>
              </div>
            ))}
        </div>
      </div>
    </div>
  )
}
