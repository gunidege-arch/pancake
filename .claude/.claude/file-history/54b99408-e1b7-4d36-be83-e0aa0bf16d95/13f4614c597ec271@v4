@tailwind base;
@tailwind components;
@tailwind utilities;

/* ═══════════════════════════════════════════════════════════
   DARK THEME — Bilibili-inspired night mode
   ═══════════════════════════════════════════════════════════ */
:root {
  --bg-primary: #0d0d12;
  --bg-secondary: #14141a;
  --bg-card: #1a1a24;
  --bg-card-hover: #22222e;
  --bg-sidebar: #0f0f15;
  --border: #23232d;
  --text-primary: #ececf1;
  --text-secondary: #a0a0b0;
  --text-muted: #6b6b7b;
  --accent: #fb7299;
  --accent-soft: rgba(251,114,153,.15);
  --accent-hover: #fc8bab;
  --danger: #f87171;
  --success: #4ade80;
  --card-shadow: 0 1px 3px rgba(0,0,0,.3);
  --card-shadow-hover: 0 8px 28px rgba(0,0,0,.5);
}

body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Noto Sans SC", "Helvetica Neue", Arial, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: var(--bg-primary);
  color: var(--text-primary);
  padding-top: env(safe-area-inset-top, 0px);
  padding-bottom: env(safe-area-inset-bottom, 0px);
  padding-left: env(safe-area-inset-left, 0px);
  padding-right: env(safe-area-inset-right, 0px);
}

iframe { border: none; }

/* scrollbar */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #2a2a36; border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: #3a3a48; }

/* ═══════════════════════════════════════════════════════════
   RESULTS GRID — mobile 2-col, comfy spacing
   ═══════════════════════════════════════════════════════════ */
.results-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
  max-width: 100%;
}

@media (min-width: 640px) {
  .results-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 640px;
  }
}

@media (min-width: 1024px) {
  .results-grid {
    grid-template-columns: repeat(3, 1fr);
    max-width: 900px;
  }
}

@media (min-width: 1400px) {
  .results-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    max-width: 1200px;
  }
}

/* ═══════════════════════════════════════════════════════════
   RESULT CARD
   ═══════════════════════════════════════════════════════════ */
.rc-card {
  border-radius: 10px;
  background: var(--bg-card);
  overflow: hidden;
  border: none;
  padding: 0;
  text-align: left;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  box-shadow: var(--card-shadow);
  display: flex;
  flex-direction: column;
  font-family: inherit;
}

.rc-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--card-shadow-hover);
  background: var(--bg-card-hover);
}

.rc-card:active { transform: scale(.98); }

/* cover */
.rc-thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #0a0a14;
  overflow: hidden;
}

.rc-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}

.rc-card:hover .rc-thumb-img { transform: scale(1.05); }

.rc-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #14142b 0%, #1a1a3e 50%, #0d1b33 100%);
}

.rc-thumb-error {
  background: linear-gradient(135deg, #2d1b1b 0%, #3e1a1a 50%, #330d0d 100%);
}

/* play overlay */
.rc-thumb-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  transition: background 0.25s;
}

.rc-card:hover .rc-thumb-overlay { background: rgba(0,0,0,.4); }

.rc-play-circle {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: rgba(251,114,153,.9);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(.8);
  transition: opacity 0.25s, transform 0.25s;
  box-shadow: 0 4px 20px rgba(251,114,153,.45);
}

.rc-card:hover .rc-play-circle {
  opacity: 1;
  transform: scale(1);
}

/* info */
.rc-info {
  padding: 0.6rem 0.7rem 0.7rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.rc-title {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}

.rc-source-tag {
  font-size: 0.66rem;
  font-weight: 500;
  color: var(--text-muted);
  letter-spacing: 0.01em;
}

/* ═══════════════════════════════════════════════════════════
   SIDEBAR
   ═══════════════════════════════════════════════════════════ */
.sidebar {
  background: var(--bg-sidebar);
  border-right: 1px solid var(--border);
}

.sidebar-overlay {
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(4px);
}

/* ═══════════════════════════════════════════════════════════
   SEARCH BAR
   ═══════════════════════════════════════════════════════════ */
.search-input {
  background: var(--bg-card);
  border: 1px solid var(--border);
  color: var(--text-primary);
  caret-color: var(--accent);
}

.search-input::placeholder { color: var(--text-muted); }

.search-input:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-soft);
  outline: none;
}

.search-btn {
  background: linear-gradient(135deg, #fb7299 0%, #f9597a 100%);
  border: none;
  color: #fff;
  font-weight: 600;
  transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
  box-shadow: 0 2px 8px rgba(251,114,153,.35);
}

.search-btn:hover:not(:disabled) {
  transform: scale(1.04);
  box-shadow: 0 4px 16px rgba(251,114,153,.5);
}

.search-btn:active:not(:disabled) { transform: scale(.96); }

.search-btn:disabled {
  opacity: .45;
  box-shadow: none;
}

/* ═══════════════════════════════════════════════════════════
   SETTINGS PANEL
   ═══════════════════════════════════════════════════════════ */
.settings-overlay {
  position: fixed;
  inset: 0;
  z-index: 90;
  background: rgba(0,0,0,.5);
  backdrop-filter: blur(3px);
  animation: fadeIn .18s ease;
}

.settings-panel {
  position: fixed;
  right: 0;
  top: 0;
  bottom: 0;
  width: 340px;
  max-width: 88vw;
  z-index: 91;
  background: var(--bg-secondary);
  border-left: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  animation: slideInRight .22s ease;
  box-shadow: -4px 0 24px rgba(0,0,0,.4);
}

@keyframes slideInRight {
  from { transform: translateX(100%); }
  to { transform: translateX(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.settings-section {
  background: var(--bg-card);
  border-radius: 10px;
  border: 1px solid var(--border);
  overflow: hidden;
}

.settings-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.85rem 1rem;
  transition: background 0.12s;
}

.settings-option:hover { background: rgba(255,255,255,.03); }

.settings-option + .settings-option {
  border-top: 1px solid var(--border);
}

.settings-option-label {
  font-size: 0.88rem;
  color: var(--text-primary);
}

.settings-option-desc {
  font-size: 0.72rem;
  color: var(--text-muted);
  margin-top: 1px;
}

/* toggle switch */
.toggle-switch {
  position: relative;
  width: 44px;
  height: 24px;
  flex-shrink: 0;
}

.toggle-switch input { display: none; }

.toggle-switch .toggle-track {
  position: absolute;
  inset: 0;
  border-radius: 12px;
  background: #3a3a48;
  cursor: pointer;
  transition: background 0.2s;
}

.toggle-switch input:checked + .toggle-track {
  background: var(--accent);
}

.toggle-switch .toggle-thumb {
  position: absolute;
  top: 2px;
  left: 2px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.2s;
  box-shadow: 0 1px 3px rgba(0,0,0,.3);
}

.toggle-switch input:checked + .toggle-track .toggle-thumb {
  transform: translateX(20px);
}

/* select */
.settings-select {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  color: var(--text-primary);
  padding: 0.35rem 0.6rem;
  border-radius: 6px;
  font-size: 0.82rem;
  cursor: pointer;
  outline: none;
}

.settings-select:focus {
  border-color: var(--accent);
}

/* ═══════════════════════════════════════════════════════════
   MODAL — dark adapt
   ═══════════════════════════════════════════════════════════ */
.vm-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.82);
  backdrop-filter: blur(6px);
  animation: vmFadeIn .2s ease;
  padding: 1rem;
}

@keyframes vmFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.vm-container {
  width: 100%;
  max-width: 960px;
  max-height: 90vh;
  background: #18181f;
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: vmScaleIn .25s ease;
  box-shadow: 0 16px 48px rgba(0,0,0,.6);
}

@keyframes vmScaleIn {
  from { opacity: 0; transform: scale(.94); }
  to   { opacity: 1; transform: scale(1); }
}

.vm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid #27272e;
  gap: 1rem;
}

.vm-header-left {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  min-width: 0;
}

.vm-source-tag {
  font-size: 0.7rem;
  font-weight: 600;
  color: #a1a1aa;
  background: #27272e;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  flex-shrink: 0;
}

.vm-title {
  font-size: 0.9rem;
  font-weight: 600;
  color: #f4f4f5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0;
}

.vm-header-right {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.vm-original-link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  color: #a1a1aa;
  text-decoration: none;
  padding: 0.3rem 0.6rem;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
}

.vm-original-link:hover { color: #fff; background: #27272e; }

.vm-close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: none;
  border-radius: 8px;
  color: #a1a1aa;
  background: transparent;
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
}

.vm-close-btn:hover { color: #fff; background: #27272e; }

.vm-player {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  max-height: calc(90vh - 60px);
  background: #000;
}

.vm-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #18181f;
  z-index: 5;
}

.vm-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #18181f;
  gap: 0.25rem;
  padding: 2rem;
}

.vm-fallback p { color: #a1a1aa; margin: 0; }

.vm-fallback-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.75rem;
  background: var(--accent);
  color: #fff;
  font-size: 0.9rem;
  font-weight: 600;
  border-radius: 8px;
  text-decoration: none;
  margin-top: 1rem;
  transition: background 0.15s, transform 0.15s;
}

.vm-fallback-btn:hover { background: var(--accent-hover); transform: translateY(-1px); }

.vm-iframe {
  width: 100%;
  height: 100%;
}

/* ═══════════════════════════════════════════════════════════
   SOURCE MANAGER
   ═══════════════════════════════════════════════════════════ */
.source-add-btn {
  background: var(--accent-soft);
  color: var(--accent);
  transition: background 0.15s, transform 0.15s;
}

.source-add-btn:hover {
  background: rgba(251,114,153,.25);
  transform: scale(1.08);
}

.modal-backdrop {
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(4px);
}

.modal-card {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
}

.modal-input {
  background: var(--bg-primary);
  border: 1px solid var(--border);
  color: var(--text-primary);
}

.modal-input::placeholder { color: var(--text-muted); }

.modal-input:focus {
  border-color: var(--accent);
  outline: none;
  box-shadow: 0 0 0 3px var(--accent-soft);
}

.modal-btn-primary {
  background: var(--accent);
  color: #fff;
  transition: background 0.15s, transform 0.15s;
}

.modal-btn-primary:hover:not(:disabled) { background: var(--accent-hover); }

.modal-btn-secondary {
  color: var(--text-secondary);
  transition: background 0.15s, color 0.15s;
}

.modal-btn-secondary:hover { background: var(--bg-card); color: var(--text-primary); }

/* ═══════════════════════════════════════════════════════════
   ANIMATIONS
   ═══════════════════════════════════════════════════════════ */
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 2px 8px rgba(251,114,153,.35); }
  50% { box-shadow: 0 2px 16px rgba(251,114,153,.55); }
}

.search-btn-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

@keyframes spin-slow {
  to { transform: rotate(360deg); }
}

.animate-spin-slow {
  animation: spin-slow 3s linear infinite;
}

/* ═══════════════════════════════════════════════════════════
   SPLASH SCREEN — glassmorphism + neon dissolve
   ═══════════════════════════════════════════════════════════ */
.splash-overlay {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
}

/* ── Animated neon gradient background ─────────────────── */
.splash-bg {
  position: absolute;
  inset: 0;
  background: #07070c;
}

.splash-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.28;
  will-change: transform;
}

.splash-orb-a {
  width: 60vmax;
  height: 60vmax;
  background: radial-gradient(circle, #ff00cc33 0%, #ff00cc00 60%);
  top: -20%;
  left: -15%;
  animation: orbFloatA 14s ease-in-out infinite;
}

.splash-orb-b {
  width: 50vmax;
  height: 50vmax;
  background: radial-gradient(circle, #3333ff33 0%, #3333ff00 60%);
  bottom: -25%;
  right: -10%;
  animation: orbFloatB 16s ease-in-out infinite;
}

.splash-orb-c {
  width: 40vmax;
  height: 40vmax;
  background: radial-gradient(circle, #ff00cc22 30%, #7928ca22 70%, transparent);
  top: 45%;
  left: 50%;
  transform: translate(-50%, -50%) translate(var(--mx, 0px), var(--my, 0px));
  transition: transform 0.8s ease-out;
  animation: orbPulse 8s ease-in-out infinite;
}

@keyframes orbFloatA {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(8vmax, 6vmax) scale(1.15); }
  66% { transform: translate(-4vmax, -3vmax) scale(0.9); }
}

@keyframes orbFloatB {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-6vmax, -8vmax) scale(1.1); }
  66% { transform: translate(5vmax, 3vmax) scale(0.85); }
}

@keyframes orbPulse {
  0%, 100% { opacity: 0.22; }
  50% { opacity: 0.38; }
}

/* ── Glass card ────────────────────────────────────────── */
.splash-glass {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.1rem;
  padding: 2.8rem 2.2rem;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  box-shadow:
    0 8px 40px rgba(0, 0, 0, 0.5),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  animation: glassEnter 1s cubic-bezier(.22, .61, .36, 1) both;
}

@keyframes glassEnter {
  from {
    opacity: 0;
    transform: translateY(30px) scale(.94);
    backdrop-filter: blur(0px);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
    backdrop-filter: blur(24px);
  }
}

/* top shimmer line on glass card */
.splash-shimmer-line {
  position: absolute;
  top: 0;
  left: 15%;
  right: 15%;
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.12) 30%,
    rgba(255, 255, 255, 0.25) 50%,
    rgba(255, 255, 255, 0.12) 70%,
    transparent 100%
  );
}

/* ── Title — brushed-metal + neon-flow effect ──────────── */
.splash-title {
  margin: 0;
  font-family: "Cinzel Decorative", "Cormorant Garamond", "ZCOOL XiaoWei", "Noto Serif SC", serif;
  font-weight: 400;
  font-size: clamp(1.6rem, 5vw, 2.8rem);
  letter-spacing: 0.12em;
  text-align: center;
  line-height: 1.3;
  position: relative;
}

.splash-title-text {
  display: block;
  /* metallic silver base */
  background: linear-gradient(
    180deg,
    #e8e8ee 0%,
    #b8b8c8 30%,
    #f0f0f8 50%,
    #a0a0b8 70%,
    #d0d0e0 100%
  );
  background-size: 100% 300%;
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;

  /* neon glow */
  filter: drop-shadow(0 0 18px rgba(180, 160, 220, 0.45));
  animation: metallicFlow 4s ease-in-out infinite, textShimmer 3s ease-in-out infinite;
}

@keyframes metallicFlow {
  0%, 100% { background-position: 0% 0%; }
  50% { background-position: 0% 100%; }
}

@keyframes textShimmer {
  0%, 100% {
    filter: drop-shadow(0 0 18px rgba(180, 160, 220, 0.45));
  }
  50% {
    filter: drop-shadow(0 0 32px rgba(200, 140, 220, 0.7));
  }
}

/* ── Decorative rule ───────────────────────────────────── */
.splash-rule {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: 0.5rem;
}

.splash-rule::before,
.splash-rule::after {
  content: "";
  height: 1px;
  width: 48px;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.15),
    transparent
  );
}

.splash-rule-diamond {
  display: block;
  width: 5px;
  height: 5px;
  background: rgba(255, 255, 255, 0.3);
  transform: rotate(45deg);
  animation: diamondPulse 2.2s ease-in-out infinite;
}

@keyframes diamondPulse {
  0%, 100% { opacity: 0.25; transform: rotate(45deg) scale(1); }
  50% { opacity: 0.7; transform: rotate(45deg) scale(1.5); }
}

/* ── Hint text ─────────────────────────────────────────── */
.splash-hint {
  margin: 0;
  font-family: "Inter", "PingFang SC", "Noto Sans SC", system-ui, sans-serif;
  font-size: 0.7rem;
  font-weight: 300;
  letter-spacing: 0.28em;
  color: rgba(255, 255, 255, 0.28);
  animation: hintBreathe 2.8s ease-in-out infinite;
}

@keyframes hintBreathe {
  0%, 100% { opacity: 0.22; }
  50% { opacity: 0.55; }
}

/* ── EXIT ANIMATION — blur + fade + scale (smoke dissolve) ── */
.splash-exit {
  pointer-events: none;
  animation: splashDissolve 2s cubic-bezier(.4, 0, .6, 1) forwards;
}

.splash-exit .splash-glass {
  animation: glassDissolve 2s cubic-bezier(.4, 0, .6, 1) forwards;
}

.splash-exit .splash-orb {
  animation-duration: 2s !important;
  animation-name: orbFadeOut !important;
  animation-fill-mode: forwards !important;
  animation-timing-function: ease-in !important;
}

@keyframes splashDissolve {
  0% {
    opacity: 1;
    backdrop-filter: blur(0px);
    -webkit-backdrop-filter: blur(0px);
  }
  40% {
    opacity: 0.6;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  100% {
    opacity: 0;
    backdrop-filter: blur(40px);
    -webkit-backdrop-filter: blur(40px);
  }
}

@keyframes glassDissolve {
  0% {
    opacity: 1;
    transform: scale(1);
    filter: blur(0px);
  }
  100% {
    opacity: 0;
    transform: scale(0.92);
    filter: blur(20px);
  }
}

@keyframes orbFadeOut {
  0% { opacity: 0.28; }
  100% { opacity: 0; }
}

/* ── Fallback: reduced motion ──────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .splash-exit {
    animation: splashDissolve 0.5s ease-in forwards;
  }

  .splash-exit .splash-glass {
    animation: glassDissolve 0.5s ease-in forwards;
  }

  .splash-orb {
    animation: none !important;
  }

  .splash-title-text {
    animation: none;
  }
}
