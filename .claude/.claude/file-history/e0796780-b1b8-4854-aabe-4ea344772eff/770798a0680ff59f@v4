import { useState } from "react";

interface Props {
  title: string;
  thumbnailUrl?: string;
  sourceName: string;
  hasPlayable: boolean;
  onOpen: () => void;
}

export default function VideoCard({
  title,
  thumbnailUrl,
  sourceName,
  hasPlayable,
  onOpen,
}: Props) {
  const [imgFailed, setImgFailed] = useState(false);

  return (
    <button
      type="button"
      className="rc-card group"
      onClick={onOpen}
      aria-label={hasPlayable ? `播放 ${title}` : `打开 ${title}`}
    >
      {/* ── Cover ──────────────────────────────────── */}
      <div className="rc-thumb">
        {thumbnailUrl && !imgFailed ? (
          <img
            src={thumbnailUrl}
            alt={title}
            className="rc-thumb-img"
            loading="lazy"
            referrerPolicy="no-referrer"
            onError={() => setImgFailed(true)}
          />
        ) : (
          <div className="rc-thumb-placeholder">
            {hasPlayable ? (
              <svg className="w-10 h-10 text-white/25" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            ) : (
              <svg className="w-10 h-10 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5}
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            )}
          </div>
        )}

        {/* Play overlay — only for playable cards */}
        {hasPlayable && (
          <div className="rc-thumb-overlay">
            <div className="rc-play-circle">
              <svg className="w-7 h-7 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
        )}
      </div>

      {/* ── Info ───────────────────────────────────── */}
      <div className="rc-info">
        <p className="rc-title" title={title}>{title}</p>
        <span className="rc-source-tag">来源：{sourceName}</span>
      </div>
    </button>
  );
}
