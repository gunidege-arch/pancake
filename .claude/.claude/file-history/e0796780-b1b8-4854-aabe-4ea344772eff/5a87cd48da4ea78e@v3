@tailwind base;
@tailwind components;
@tailwind utilities;

/* ── Base ──────────────────────────────────────────────── */
body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "Noto Sans SC", sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: #f5f6f8;
}

iframe {
  border: none;
}

/* ── Section headings ──────────────────────────────────── */
.section-heading {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.95rem;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 0.875rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid #e5e7eb;
}

/* ═══════════════════════════════════════════════════════════
   VIDEO GRID  (3–4 columns)
   ═══════════════════════════════════════════════════════════ */
.video-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 640px) {
  .video-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .video-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (min-width: 1400px) {
  .video-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
}

/* ── Video Card ────────────────────────────────────────── */
.vc-card {
  border-radius: 10px;
  background: #fff;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 1px 3px rgba(0,0,0,.06);
}

.vc-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,.14);
}

/* Thumbnail area — 16:9 */
.vc-thumb {
  position: relative;
  display: block;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #0f0f1a;
  border: none;
  padding: 0;
  cursor: pointer;
  overflow: hidden;
}

.vc-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}

.vc-card:hover .vc-thumb-img { transform: scale(1.05); }

.vc-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #14142b 0%, #1a1a3e 50%, #0d1b33 100%);
}

/* Hover overlay */
.vc-thumb-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0);
  transition: background 0.25s;
}

.vc-card:hover .vc-thumb-overlay { background: rgba(0,0,0,.35); }

.vc-play-circle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(239,68,68,.9);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(.8);
  transition: opacity 0.25s, transform 0.25s;
  box-shadow: 0 4px 20px rgba(239,68,68,.5);
}

.vc-card:hover .vc-play-circle {
  opacity: 1;
  transform: scale(1);
}

/* Info bar */
.vc-info {
  padding: 0.625rem 0.75rem 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

.vc-badges {
  display: flex;
  align-items: center;
  gap: 0.375rem;
}

.vc-badge-source {
  font-size: 0.68rem;
  font-weight: 600;
  color: #6b7280;
  background: #f3f4f6;
  padding: 0.1rem 0.45rem;
  border-radius: 3px;
  letter-spacing: 0.01em;
}

.vc-title {
  font-size: 0.85rem;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}

.vc-watch-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.375rem;
  padding: 0.4rem 1rem;
  font-size: 0.8rem;
  font-weight: 600;
  color: #ef4444;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: 6px;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  align-self: flex-start;
  margin-top: 0.15rem;
}

.vc-watch-btn:hover {
  background: #fee2e2;
  border-color: #fca5a5;
}

/* ═══════════════════════════════════════════════════════════
   WEBPAGE GRID  (2 columns for non-video results)
   ═══════════════════════════════════════════════════════════ */
.webpage-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 1024px) {
  .webpage-grid { grid-template-columns: repeat(2, 1fr); }
}

/* ── Generic result card ───────────────────────────────── */
.result-card {
  border-radius: 10px;
  background: #fff;
  box-shadow: 0 1px 3px rgba(0,0,0,.06);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.15s;
}

.result-card:hover { box-shadow: 0 4px 14px rgba(0,0,0,.1); }

.result-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.625rem 0.875rem;
  border-bottom: 1px solid #f0f0f0;
  background: #fafbfc;
}

.result-card-body { flex: 1; }

.result-card-badge {
  font-size: 0.68rem;
  padding: 0.1rem 0.45rem;
  border-radius: 999px;
  font-weight: 500;
  white-space: nowrap;
  flex-shrink: 0;
}

.badge-error   { color: #dc2626; background: #fef2f2; }
.badge-content { color: #2563eb; background: #eff6ff; }
.badge-embed   { color: #16a34a; background: #f0fdf4; }
.badge-default { color: #6b7280; background: #f3f4f6; }

/* ── Readable content ──────────────────────────────────── */
.result-content {
  max-height: 500px;
  overflow-y: auto;
  padding: 1rem;
}

.result-content img { max-width: 100%; height: auto; border-radius: 0.25rem; }
.result-content a   { color: #2563eb; text-decoration: underline; }

/* ═══════════════════════════════════════════════════════════
   VIDEO MODAL
   ═══════════════════════════════════════════════════════════ */
.vm-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.75);
  backdrop-filter: blur(6px);
  animation: vmFadeIn .2s ease;
  padding: 1rem;
}

@keyframes vmFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.vm-container {
  width: 100%;
  max-width: 960px;
  max-height: 90vh;
  background: #18181b;
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: vmScaleIn .25s ease;
  box-shadow: 0 16px 48px rgba(0,0,0,.5);
}

@keyframes vmScaleIn {
  from { opacity: 0; transform: scale(.94); }
  to   { opacity: 1; transform: scale(1); }
}

/* Header */
.vm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid #27272a;
  gap: 1rem;
}

.vm-header-left {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  min-width: 0;
}

.vm-source-tag {
  font-size: 0.7rem;
  font-weight: 600;
  color: #a1a1aa;
  background: #27272a;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  flex-shrink: 0;
}

.vm-title {
  font-size: 0.9rem;
  font-weight: 600;
  color: #f4f4f5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0;
}

.vm-header-right {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.vm-original-link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  color: #a1a1aa;
  text-decoration: none;
  padding: 0.3rem 0.6rem;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
}

.vm-original-link:hover { color: #fff; background: #27272a; }

.vm-close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: none;
  border-radius: 8px;
  color: #a1a1aa;
  background: transparent;
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
}

.vm-close-btn:hover { color: #fff; background: #27272a; }

/* Player area — 16:9 capped */
.vm-player {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  max-height: calc(90vh - 60px);
  background: #000;
}

.vm-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #18181b;
  z-index: 5;
}

.vm-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #18181b;
  gap: 0.25rem;
  padding: 2rem;
}

.vm-fallback-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.75rem;
  background: #2563eb;
  color: #fff;
  font-size: 0.9rem;
  font-weight: 600;
  border-radius: 8px;
  text-decoration: none;
  margin-top: 1rem;
  transition: background 0.15s;
}

.vm-fallback-btn:hover { background: #1d4ed8; }

.vm-iframe {
  width: 100%;
  height: 100%;
}
