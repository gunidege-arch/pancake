export interface SearchSource {
  id: number;
  name: string;
  search_url_template: string;
  allow_embed: boolean;
}

export interface SearchResultItem {
  source_id: number;
  source_name: string;
  type: "embed" | "content" | "video" | "error";
  success: boolean;
  url?: string;
  content?: string;
  original_url?: string;
  error?: string;
  resource_type?: "video" | "webpage";
  thumbnail_url?: string;
  title?: string;
  embed_url?: string;
  video_url?: string;
}

export interface SearchResponse {
  query: string;
  results: SearchResultItem[];
}

/** Normalised card — the only shape the UI layer should ever see. */
export interface NormalizedCard {
  title: string;
  thumbnail: string | null;
  videoUrl: string | null;
  sourceName: string;
  originalUrl: string | null;
}

/** Convert any backend result into the standard NormalizedCard shape. */
export function normalizeResult(item: SearchResultItem): NormalizedCard {
  return {
    title: item.title || item.source_name,
    thumbnail: item.thumbnail_url || null,
    videoUrl: item.video_url || item.embed_url || null,
    sourceName: item.source_name,
    originalUrl: item.original_url || item.url || null,
  };
}
