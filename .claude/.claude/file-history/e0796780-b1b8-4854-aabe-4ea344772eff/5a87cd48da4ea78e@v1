@tailwind base;
@tailwind components;
@tailwind utilities;

body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "Noto Sans SC", sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

iframe {
  border: none;
  width: 100%;
  height: 100%;
  min-height: 400px;
}

.result-content {
  max-height: 600px;
  overflow-y: auto;
}

.result-content img {
  max-width: 100%;
  height: auto;
}

.result-content a {
  color: #2563eb;
  text-decoration: underline;
}
