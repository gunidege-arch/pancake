import { useState } from "react";

interface Props {
  title: string;
  thumbnailUrl?: string;
  sourceName: string;
  onWatch: () => void;
}

export default function VideoCard({
  title,
  thumbnailUrl,
  sourceName,
  onWatch,
}: Props) {
  const [imgFailed, setImgFailed] = useState(false);

  return (
    <div className="vc-card group">
      {/* ── Thumbnail ──────────────────────────────────── */}
      <button
        type="button"
        className="vc-thumb"
        onClick={onWatch}
        aria-label={`观看 ${title}`}
      >
        {thumbnailUrl && !imgFailed ? (
          <img
            src={thumbnailUrl}
            alt={title}
            className="vc-thumb-img"
            loading="lazy"
            referrerPolicy="no-referrer"
            onError={() => setImgFailed(true)}
          />
        ) : (
          <div className="vc-thumb-placeholder">
            <svg className="w-10 h-10 text-white/30" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        )}

        {/* Hover overlay */}
        <div className="vc-thumb-overlay">
          <div className="vc-play-circle">
            <svg className="w-7 h-7 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      </button>

      {/* ── Info ───────────────────────────────────────── */}
      <div className="vc-info">
        <div className="vc-badges">
          <span className="vc-badge-source">{sourceName}</span>
        </div>
        <p className="vc-title" title={title}>{title}</p>
        <button type="button" className="vc-watch-btn" onClick={onWatch}>
          <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z" />
          </svg>
          点击观看
        </button>
      </div>
    </div>
  );
}
