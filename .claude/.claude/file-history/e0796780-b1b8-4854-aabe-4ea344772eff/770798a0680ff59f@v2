import { useState, useRef, useCallback } from "react";

interface Props {
  title: string;
  thumbnailUrl?: string;
  embedUrl: string;
  originalUrl: string;
  sourceName: string;
}

export default function VideoCard({
  title,
  thumbnailUrl,
  embedUrl,
  originalUrl,
  sourceName,
}: Props) {
  const [playing, setPlaying] = useState(false);
  const [embedError, setEmbedError] = useState(false);
  const [loading, setLoading] = useState(false);
  const iframeRef = useRef<HTMLIFrameElement>(null);
  const pendingErrorRef = useRef(false);

  const handlePlay = useCallback(() => {
    setPlaying(true);
    setLoading(true);
  }, []);

  const handleIframeLoad = useCallback(() => {
    setLoading(false);
    // If an error was already flagged (e.g. from a previous onError), skip DOM probe
    if (pendingErrorRef.current) return;

    setTimeout(() => {
      try {
        const doc = iframeRef.current?.contentDocument;
        if (doc && doc.body && doc.body.children.length === 0 && doc.body.innerText.trim() === "") {
          setEmbedError(true);
          setPlaying(false);
        }
      } catch {
        // cross-origin – assume ok
      }
    }, 800);
  }, []);

  const handleIframeError = useCallback(() => {
    pendingErrorRef.current = true;
    setLoading(false);
    setEmbedError(true);
    setPlaying(false);
  }, []);

  return (
    <div className="video-card group">
      {/* Thumbnail / Player area */}
      <div className="video-card-media">
        {!playing ? (
          <button
            type="button"
            onClick={handlePlay}
            className="video-card-thumbnail"
            aria-label={`播放 ${title}`}
          >
            {thumbnailUrl ? (
              <img
                src={thumbnailUrl}
                alt={title}
                className="video-card-thumbnail-img"
                loading="lazy"
                referrerPolicy="no-referrer"
                onError={(e) => {
                  // Hide broken thumbnail
                  (e.target as HTMLImageElement).style.display = "none";
                }}
              />
            ) : (
              <div className="video-card-thumbnail-placeholder" />
            )}

            {/* Play button overlay */}
            <div className="video-card-play-overlay">
              <div className="video-card-play-btn">
                <svg className="w-8 h-8 text-white ml-0.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </div>
            </div>
          </button>
        ) : embedError ? (
          /* Fallback when embed is blocked */
          <div className="video-card-fallback">
            <svg className="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={1.5}
                d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            </svg>
            <p className="text-gray-400 text-sm mt-2">嵌入被网站拒绝</p>
            <a
              href={originalUrl}
              target="_blank"
              rel="noopener noreferrer"
              className="video-card-jump-btn"
            >
              <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2}
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              点击跳转观看
            </a>
          </div>
        ) : (
          <div className="video-card-player-wrapper">
            {loading && (
              <div className="video-card-player-loading">
                <svg className="animate-spin h-8 w-8 text-white/80" viewBox="0 0 24 24">
                  <circle className="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" strokeWidth="4" fill="none" />
                  <path className="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                </svg>
              </div>
            )}
            <iframe
              ref={iframeRef}
              src={embedUrl}
              title={title}
              onLoad={handleIframeLoad}
              onError={handleIframeError}
              sandbox="allow-scripts allow-same-origin allow-popups allow-forms allow-presentation"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
              className="video-card-iframe"
            />
          </div>
        )}
      </div>

      {/* Info bar */}
      <div className="video-card-info">
        <div className="video-card-title-row">
          <span className="video-card-platform-badge">{sourceName}</span>
          <span className="video-card-type-badge">视频</span>
        </div>
        <p className="video-card-title" title={title}>
          {title}
        </p>
        <a
          href={originalUrl}
          target="_blank"
          rel="noopener noreferrer"
          className="video-card-original-link"
        >
          查看原始页面 &rarr;
        </a>
      </div>
    </div>
  );
}
