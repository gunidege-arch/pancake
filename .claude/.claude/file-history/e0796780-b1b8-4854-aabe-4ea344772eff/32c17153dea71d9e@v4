import { useState, useCallback } from "react";
import type { SearchResultItem } from "../types";
import VideoCard from "./VideoCard";
import VideoModal from "./VideoModal";

interface Props {
  results: SearchResultItem[];
  query: string;
}

interface ModalData {
  title: string;
  embedUrl: string;
  originalUrl: string;
  sourceName: string;
}

export default function ResultPanel({ results, query }: Props) {
  const [modal, setModal] = useState<ModalData | null>(null);
  const openModal = useCallback((data: ModalData) => setModal(data), []);
  const closeModal = useCallback(() => setModal(null), []);

  if (results.length === 0) {
    return <p className="text-gray-400 text-center py-8">未配置搜索源，请先在侧边栏添加。</p>;
  }

  return (
    <div>
      <p className="text-sm text-gray-500 mb-4">
        搜索 &quot;{query}&quot; — 共 {results.length} 个来源
      </p>

      {/* ── Single unified grid ────────────────────────── */}
      <div className="results-grid">
        {results.map((item, idx) => {
          const embedUrl = item.embed_url || item.video_url || (item.type === "embed" ? item.url : undefined);
          const hasPlayable = Boolean(embedUrl);
          const title = item.title || item.source_name;
          const originalUrl = item.original_url || item.url || "";

          const handleOpen = () => {
            if (hasPlayable) {
              openModal({
                title,
                embedUrl: embedUrl!,
                originalUrl,
                sourceName: item.source_name,
              });
            } else if (originalUrl) {
              window.open(originalUrl, "_blank", "noopener");
            }
          };

          return (
            <VideoCard
              key={`card-${item.source_id}-${idx}`}
              title={title}
              thumbnailUrl={item.thumbnail_url}
              sourceName={item.source_name}
              hasPlayable={hasPlayable}
              onOpen={handleOpen}
            />
          );
        })}
      </div>

      {/* ── Modal ────────────────────────────────────────── */}
      <VideoModal
        open={modal !== null}
        onClose={closeModal}
        title={modal?.title ?? ""}
        embedUrl={modal?.embedUrl ?? ""}
        originalUrl={modal?.originalUrl ?? ""}
        sourceName={modal?.sourceName ?? ""}
      />
    </div>
  );
}
