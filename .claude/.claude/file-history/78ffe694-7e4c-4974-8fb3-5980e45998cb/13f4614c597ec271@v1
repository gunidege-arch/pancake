@tailwind base;
@tailwind components;
@tailwind utilities;

/* ── Base ──────────────────────────────────────────────── */
body {
  margin: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial,
    "Noto Sans SC", sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  background: #f5f6f8;
}

iframe {
  border: none;
}

/* ═══════════════════════════════════════════════════════════
   UNIFIED RESULTS GRID  (1→2→3→4 columns)
   ═══════════════════════════════════════════════════════════ */
.results-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 640px) {
  .results-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (min-width: 1024px) {
  .results-grid { grid-template-columns: repeat(3, 1fr); }
}

@media (min-width: 1400px) {
  .results-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; }
}

/* ═══════════════════════════════════════════════════════════
   RESULT CARD  (unified for all result types)
   ═══════════════════════════════════════════════════════════ */
.rc-card {
  border-radius: 10px;
  background: #fff;
  overflow: hidden;
  border: none;
  padding: 0;
  text-align: left;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 1px 3px rgba(0,0,0,.06);
  display: flex;
  flex-direction: column;
  font-family: inherit;
}

.rc-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,.14);
}

/* ── Cover area (16:9) ────────────────────────────────── */
.rc-thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  background: #0f0f1a;
  overflow: hidden;
}

.rc-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}

.rc-card:hover .rc-thumb-img { transform: scale(1.05); }

.rc-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #14142b 0%, #1a1a3e 50%, #0d1b33 100%);
}

.rc-thumb-error {
  background: linear-gradient(135deg, #2d1b1b 0%, #3e1a1a 50%, #330d0d 100%);
}

/* ── Play overlay (only on playable cards) ────────────── */
.rc-thumb-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0);
  transition: background 0.25s;
}

.rc-card:hover .rc-thumb-overlay { background: rgba(0,0,0,.35); }

.rc-play-circle {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(239,68,68,.9);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transform: scale(.8);
  transition: opacity 0.25s, transform 0.25s;
  box-shadow: 0 4px 20px rgba(239,68,68,.5);
}

.rc-card:hover .rc-play-circle {
  opacity: 1;
  transform: scale(1);
}

/* ── Info bar ─────────────────────────────────────────── */
.rc-info {
  padding: 0.625rem 0.75rem 0.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.rc-title {
  font-size: 0.85rem;
  font-weight: 600;
  color: #1f2937;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}

.rc-source-tag {
  font-size: 0.68rem;
  font-weight: 500;
  color: #9ca3af;
  letter-spacing: 0.01em;
}

/* ═══════════════════════════════════════════════════════════
   VIDEO MODAL
   ═══════════════════════════════════════════════════════════ */
.vm-overlay {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,.75);
  backdrop-filter: blur(6px);
  animation: vmFadeIn .2s ease;
  padding: 1rem;
}

@keyframes vmFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.vm-container {
  width: 100%;
  max-width: 960px;
  max-height: 90vh;
  background: #18181b;
  border-radius: 14px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: vmScaleIn .25s ease;
  box-shadow: 0 16px 48px rgba(0,0,0,.5);
}

@keyframes vmScaleIn {
  from { opacity: 0; transform: scale(.94); }
  to   { opacity: 1; transform: scale(1); }
}

.vm-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 1.25rem;
  border-bottom: 1px solid #27272a;
  gap: 1rem;
}

.vm-header-left {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  min-width: 0;
}

.vm-source-tag {
  font-size: 0.7rem;
  font-weight: 600;
  color: #a1a1aa;
  background: #27272a;
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  flex-shrink: 0;
}

.vm-title {
  font-size: 0.9rem;
  font-weight: 600;
  color: #f4f4f5;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin: 0;
}

.vm-header-right {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-shrink: 0;
}

.vm-original-link {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-size: 0.75rem;
  color: #a1a1aa;
  text-decoration: none;
  padding: 0.3rem 0.6rem;
  border-radius: 6px;
  transition: color 0.15s, background 0.15s;
}

.vm-original-link:hover { color: #fff; background: #27272a; }

.vm-close-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: none;
  border-radius: 8px;
  color: #a1a1aa;
  background: transparent;
  cursor: pointer;
  transition: color 0.15s, background 0.15s;
}

.vm-close-btn:hover { color: #fff; background: #27272a; }

.vm-player {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  max-height: calc(90vh - 60px);
  background: #000;
}

.vm-loading {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #18181b;
  z-index: 5;
}

.vm-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #18181b;
  gap: 0.25rem;
  padding: 2rem;
}

.vm-fallback-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.7rem 1.75rem;
  background: #2563eb;
  color: #fff;
  font-size: 0.9rem;
  font-weight: 600;
  border-radius: 8px;
  text-decoration: none;
  margin-top: 1rem;
  transition: background 0.15s;
}

.vm-fallback-btn:hover { background: #1d4ed8; }

.vm-iframe {
  width: 100%;
  height: 100%;
}
