# ============================================================
# 无需设置任何环境变量！
# ============================================================
# Vercel 的 vercel.json 已将 /api/* 请求反向代理到 Render 后端。
# 本地开发时，Vite proxy 将 /api 转发到 localhost:8000。
# 前后两端都不需要 VITE_API_BASE_URL。

# lxserver 完整播放器地址（可选）
# VITE_LXSERVER_URL=https://pancake-music.onrender.com
